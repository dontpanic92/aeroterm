<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>
    <ResourceDictionary>
      <ControlTheme x:Key="{x:Type Separator}" TargetType="Separator">
        <Setter Property="Background" Value="{DynamicResource StrokeDefaultBrush}" />
        <Setter Property="Height" Value="1" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,4" />
        <Setter Property="Template">
          <ControlTemplate>
            <Border Background="{TemplateBinding Background}"
                    Height="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center" />
          </ControlTemplate>
        </Setter>
      </ControlTheme>
    </ResourceDictionary>
  </Styles.Resources>

  <!-- Visual Studio-style menu divider: inset from both edges and tighter vertical rhythm. -->
  <Style Selector="MenuItem Separator, ContextMenu Separator, MenuFlyoutPresenter Separator">
    <Setter Property="Background" Value="{DynamicResource MenuSeparatorBrush}" />
    <Setter Property="Margin" Value="{DynamicResource MenuSeparatorMargin}" />
  </Style>
</Styles>
