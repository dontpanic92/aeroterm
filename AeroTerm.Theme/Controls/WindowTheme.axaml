<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="using:Avalonia.Controls.Primitives">
  <Styles.Resources>
    <ResourceDictionary>
    <ControlTheme x:Key="{x:Type Window}"
                TargetType="Window">
    <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource FontFamilyUI}" />
    <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
    <Setter Property="Template">
      <ControlTemplate>
        <!--
          Wrap ContentPresenter in a Panel with a dedicated Background border so
          the Window's Background property (SurfaceBackgroundBrush by default)
          actually paints. Avalonia's default Window template does this via the
          internal Window chrome, but a bare ControlTemplate must render it
          explicitly — otherwise dialogs that don't override Window.Template
          (e.g. SettingsWindow) appear transparent on platforms where the OS
          window itself is transparent (Windows with TransparencyLevelHint).
        -->
        <Panel>
          <Border Background="{TemplateBinding Background}" />
          <VisualLayerManager Name="PART_VisualLayerManager"
                              EnableOverlayLayer="False">
            <ContentPresenter Name="PART_ContentPresenter"
                              Margin="{TemplateBinding Padding}"
                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                              Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}" />
          </VisualLayerManager>
        </Panel>
      </ControlTemplate>
    </Setter>
    </ControlTheme>

    <!--
      Popup hosts (PopupRoot for OS-window-based popups, OverlayPopupHost for
      overlay-layer popups) derive from WindowBase / TopLevel and otherwise
      pick up the Window ControlTheme, painting an opaque rectangular fill
      behind the rounded popup content. Explicit ControlThemes here keep the
      popup root transparent so only the inner FlyoutPresenter / MenuFlyout
      Border (with its CornerRadius) draws.
    -->
    <ControlTheme x:Key="{x:Type primitives:PopupRoot}"
                  TargetType="primitives:PopupRoot">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="TransparencyBackgroundFallback" Value="Transparent" />
      <!--
        Try the most "modern" transparency on each platform, falling back
        gracefully:
          * macOS < 26: AcrylicBlur maps to NSVisualEffectView vibrancy.
            macOS 26+ Liquid Glass is installed by PopupTransparencyHelper.
          * Windows: Mica on Win11, AcrylicBlur on Win10, Blur on older.
          * Linux: Blur if compositor supports it, otherwise Transparent.
      -->
      <Setter Property="TransparencyLevelHint" Value="Mica,AcrylicBlur,Blur,Transparent" />
      <Setter Property="Template">
        <ControlTemplate>
          <VisualLayerManager>
            <ContentPresenter Name="PART_ContentPresenter"
                              Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              Padding="{TemplateBinding Padding}" />
          </VisualLayerManager>
        </ControlTemplate>
      </Setter>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type primitives:OverlayPopupHost}"
                  TargetType="primitives:OverlayPopupHost">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Template">
        <ControlTemplate>
          <ContentPresenter Name="PART_ContentPresenter"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            Padding="{TemplateBinding Padding}" />
        </ControlTemplate>
      </Setter>
    </ControlTheme>
    </ResourceDictionary>
  </Styles.Resources>

  <Style Selector="Window.dialog">
    <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="FontFamily" Value="{DynamicResource FontFamilyUI}" />
    <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
    <Setter Property="Padding" Value="{DynamicResource ControlPaddingDefault}" />
  </Style>
</Styles>
