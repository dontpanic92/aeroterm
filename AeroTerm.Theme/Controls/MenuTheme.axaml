<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>
    <ResourceDictionary>
      <ControlTheme x:Key="AeroTermTopLevelMenuItemTheme"
                    TargetType="MenuItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{DynamicResource MenuBarItemCornerRadius}" />
        <Setter Property="Foreground" Value="{DynamicResource MenuItemForegroundBrush}" />
        <Setter Property="FontFamily" Value="{DynamicResource FontFamilyUI}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeMenu}" />
        <Setter Property="MinHeight" Value="{DynamicResource MenuBarHeight}" />
        <Setter Property="Padding" Value="{DynamicResource MenuBarItemPadding}" />
        <Setter Property="Template">
          <ControlTemplate>
            <Border Name="PART_Root"
                    MinHeight="{TemplateBinding MinHeight}"
                    Padding="{TemplateBinding Padding}"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{TemplateBinding CornerRadius}">
              <Panel>
                <ContentPresenter Name="PART_HeaderPresenter"
                                  Padding="{DynamicResource MenuBarItemHeaderPadding}"
                                  VerticalAlignment="Center"
                                  HorizontalContentAlignment="Center"
                                  VerticalContentAlignment="Center"
                                  RecognizesAccessKey="True"
                                  Content="{TemplateBinding Header}"
                                  ContentTemplate="{TemplateBinding HeaderTemplate}"
                                  Foreground="{TemplateBinding Foreground}" />
                <Popup Name="PART_Popup"
                       IsLightDismissEnabled="True"
                       IsOpen="{TemplateBinding IsSubMenuOpen, Mode=TwoWay}"
                       Placement="BottomEdgeAlignedLeft"
                       WindowManagerAddShadowHint="False">
                  <Border Name="PART_MenuPopupChrome"
                          MinWidth="{DynamicResource MenuMinWidth}"
                          Padding="{DynamicResource MenuPopupPadding}"
                          Background="{DynamicResource MenuPopupBackgroundBrush}"
                          BorderBrush="{DynamicResource MenuPopupBorderBrush}"
                          BorderThickness="{DynamicResource BorderThicknessThin}"
                          BoxShadow="{DynamicResource MenuPopupBoxShadow}"
                          CornerRadius="{DynamicResource MenuPopupCornerRadius}"
                          ClipToBounds="True">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                      <ItemsPresenter Name="PART_ItemsPresenter"
                                      Grid.IsSharedSizeScope="True"
                                      ItemsPanel="{TemplateBinding ItemsPanel}"
                                      KeyboardNavigation.TabNavigation="Continue" />
                    </ScrollViewer>
                  </Border>
                </Popup>
              </Panel>
            </Border>
          </ControlTemplate>
        </Setter>

        <Style Selector="^:pointerover /template/ Border#PART_Root">
          <Setter Property="Background" Value="{DynamicResource MenuBarItemHoverBrush}" />
        </Style>
        <Style Selector="^:pressed /template/ Border#PART_Root, ^:selected /template/ Border#PART_Root, ^:open /template/ Border#PART_Root">
          <Setter Property="Background" Value="{DynamicResource MenuBarItemPressedBrush}" />
        </Style>
        <Style Selector="^:disabled">
          <Setter Property="Foreground" Value="{DynamicResource MenuItemDisabledForegroundBrush}" />
        </Style>
      </ControlTheme>

      <ControlTheme x:Key="{x:Type Menu}"
                    TargetType="Menu">
        <Setter Property="Background" Value="{DynamicResource MenuBarBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Height" Value="{DynamicResource MenuBarHeight}" />
        <Setter Property="ItemContainerTheme" Value="{StaticResource AeroTermTopLevelMenuItemTheme}" />
        <Setter Property="Template">
          <ControlTemplate>
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    HorizontalAlignment="Stretch"
                    Padding="{TemplateBinding Padding}">
              <ItemsPresenter Name="PART_ItemsPresenter"
                              VerticalAlignment="Stretch"
                              ItemsPanel="{TemplateBinding ItemsPanel}"
                              KeyboardNavigation.TabNavigation="Continue" />
            </Border>
          </ControlTemplate>
        </Setter>
      </ControlTheme>
    </ResourceDictionary>
  </Styles.Resources>
</Styles>
