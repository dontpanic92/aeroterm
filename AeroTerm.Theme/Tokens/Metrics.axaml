<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">
  <!-- Geometry tokens: corner radii, thicknesses, and a spacing scale. -->

  <CornerRadius x:Key="CornerRadiusSm">4</CornerRadius>
  <CornerRadius x:Key="CornerRadiusMd">8</CornerRadius>
  <CornerRadius x:Key="CornerRadiusLg">12</CornerRadius>
  <CornerRadius x:Key="CornerRadiusPill">999</CornerRadius>
  <CornerRadius x:Key="MenuItemCornerRadius">4</CornerRadius>
  <CornerRadius x:Key="MenuPopupCornerRadius">6</CornerRadius>
  <CornerRadius x:Key="MenuBarItemCornerRadius">0</CornerRadius>

  <Thickness x:Key="BorderThicknessThin">1</Thickness>
  <Thickness x:Key="BorderThicknessMedium">1.5</Thickness>
  <Thickness x:Key="BorderThicknessFocus">2</Thickness>

  <!--
    IDE-style compact padding.

    The macOS values are intentionally top-heavy (top ≈ bottom + 2 px) to
    optically center SF Pro / -apple-system glyphs, whose Skia-reported
    metrics leave more visual space below the baseline than above.

    Windows (Segoe UI Variable) and Linux (DejaVu/Noto via Skia) report
    balanced vertical metrics, so the same asymmetry pushes glyphs visibly
    below center. Those platforms therefore use symmetric padding —
    matching the original pre-f1747a5 proportions — applied uniformly to
    every control via DynamicResource.

    Adjust per-platform values here; no control template edits required.
  -->
  <OnPlatform x:Key="ControlPaddingTight" x:TypeArguments="Thickness" Default="6,2">
    <On Options="macOS" Content="6,3,6,1" />
  </OnPlatform>
  <OnPlatform x:Key="ControlPaddingDefault" x:TypeArguments="Thickness" Default="10,4">
    <On Options="macOS" Content="10,5,10,3" />
  </OnPlatform>
  <OnPlatform x:Key="ControlPaddingRoomy" x:TypeArguments="Thickness" Default="14,6">
    <On Options="macOS" Content="14,7,14,5" />
  </OnPlatform>
  <OnPlatform x:Key="ControlTextBaselinePadding" x:TypeArguments="Thickness" Default="0">
    <On Options="macOS" Content="0,1,0,0" />
  </OnPlatform>
  <Thickness x:Key="MenuPopupPadding">4</Thickness>
  <Thickness x:Key="MenuItemPadding">0</Thickness>
  <OnPlatform x:Key="MenuItemHeaderPadding" x:TypeArguments="Thickness" Default="0">
    <On Options="macOS" Content="0,1,0,0" />
  </OnPlatform>
  <Thickness x:Key="MenuBarItemPadding">10,0</Thickness>
  <OnPlatform x:Key="MenuBarItemHeaderPadding" x:TypeArguments="Thickness" Default="0">
    <On Options="macOS" Content="0,1,0,0" />
  </OnPlatform>
  <Thickness x:Key="MenuInputGestureMargin">20,0,8,0</Thickness>
  <Thickness x:Key="MenuChevronMargin">0,0,8,0</Thickness>
  <Thickness x:Key="MenuSeparatorMargin">4,4</Thickness>

  <sys:Double x:Key="SpacingXs">4</sys:Double>
  <sys:Double x:Key="SpacingSm">8</sys:Double>
  <sys:Double x:Key="SpacingMd">12</sys:Double>
  <sys:Double x:Key="SpacingLg">16</sys:Double>
  <sys:Double x:Key="SpacingXl">24</sys:Double>

  <!-- Compact IDE control sizing. -->
  <sys:Double x:Key="ControlMinHeight">24</sys:Double>
  <sys:Double x:Key="ControlMinWidth">88</sys:Double>
  <sys:Double x:Key="MenuMinWidth">220</sys:Double>
  <sys:Double x:Key="MenuBarHeight">30</sys:Double>
  <sys:Double x:Key="MenuItemMinHeight">24</sys:Double>
  <sys:Double x:Key="MenuIconColumnWidth">30</sys:Double>
  <sys:Double x:Key="MenuChevronColumnWidth">20</sys:Double>
  <sys:Double x:Key="ScrollBarSize">12</sys:Double>
  <sys:Double x:Key="ScrollBarSizeCollapsed">6</sys:Double>

  <sys:Double x:Key="DisabledOpacity">0.45</sys:Double>
  <sys:Double x:Key="CheckableGlyphSize">16</sys:Double>
  <sys:Double x:Key="CheckableMarkLength">8</sys:Double>
  <sys:Double x:Key="CheckableMarkThickness">2</sys:Double>
  <sys:Double x:Key="CheckableBorderThickness">1</sys:Double>
  <sys:Double x:Key="FocusStrokeThickness">2</sys:Double>
  <sys:Double x:Key="RadioInnerGlyphSize">8</sys:Double>
  <sys:Double x:Key="ProgressBarThickness">6</sys:Double>
  <sys:Double x:Key="SliderTrackThickness">4</sys:Double>
  <sys:Double x:Key="SliderThumbSize">16</sys:Double>
  <Thickness x:Key="CheckableContentMargin">8,0,0,0</Thickness>
  <Thickness x:Key="GroupBoxHeaderPadding">0,0,0,6</Thickness>
  <Thickness x:Key="GroupBoxContentPadding">12</Thickness>

  <BoxShadows x:Key="PopupBoxShadow">0 4 16 0 #33000000</BoxShadows>
  <BoxShadows x:Key="MenuPopupBoxShadow">0 3 12 0 #40000000</BoxShadows>
</ResourceDictionary>
