<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AeroTerm.ViewModels"
             xmlns:models="using:AeroTerm.Models"
             xmlns:dialogs="using:AeroTerm.Dialogs"
             x:Class="AeroTerm.Dialogs.AppearancePage"
             x:CompileBindings="True"
             x:DataType="vm:AppearancePageViewModel">
    <StackPanel Spacing="10">
        <!-- Window Effects -->
        <GroupBox Header="Window" Padding="8,8">
            <StackPanel>
                <CheckBox dialogs:SettingsSearch.Label="Window Transparency"
                          IsChecked="{Binding EnableBlurBehind, Mode=TwoWay}" Content="Enable Window Transparency" Margin="0,0,0,5" />

                <RadioButton dialogs:SettingsSearch.Label="Transparent Blur"
                             Content="Transparent" GroupName="BlurKind" Margin="20,0,0,3"
                             IsEnabled="{Binding IsTransparentEnabled}"
                             IsChecked="{Binding BlurType, Converter={x:Static vm:BlurTypeConverter.Transparent}, Mode=TwoWay}" />

                <RadioButton dialogs:SettingsSearch.Label="Gaussian Blur"
                             Content="Blur (Gaussian)" GroupName="BlurKind" Margin="20,0,0,3"
                             IsEnabled="{Binding IsGaussianEnabled}"
                             IsChecked="{Binding BlurType, Converter={x:Static vm:BlurTypeConverter.Gaussian}, Mode=TwoWay}" />

                <RadioButton dialogs:SettingsSearch.Label="Acrylic Blur"
                             Content="Acrylic Blur" GroupName="BlurKind" Margin="20,0,0,3"
                             IsEnabled="{Binding IsAcrylicEnabled}"
                             IsChecked="{Binding BlurType, Converter={x:Static vm:BlurTypeConverter.Acrylic}, Mode=TwoWay}" />

                <RadioButton dialogs:SettingsSearch.Label="Mica"
                             Content="Mica (Windows only)" GroupName="BlurKind" Margin="20,0,0,5"
                             IsEnabled="{Binding IsMicaEnabled}"
                             IsChecked="{Binding BlurType, Converter={x:Static vm:BlurTypeConverter.Mica}, Mode=TwoWay}" />

                <StackPanel dialogs:SettingsSearch.Label="Background Opacity"
                            Orientation="Horizontal" Margin="20,0,0,0">
                    <TextBlock Name="OpacityLabel" Text="Background Opacity" VerticalAlignment="Center" />
                    <Slider Value="{Binding BackgroundOpacity, Mode=TwoWay}" Width="200" Minimum="0.01" Maximum="1"
                            TickFrequency="0.01" IsSnapToTickEnabled="True" Margin="10,0"
                            AutomationProperties.LabeledBy="{Binding #OpacityLabel}"
                            IsEnabled="{Binding IsOpacityEnabled}" />
                    <TextBlock Text="{Binding OpacityLabel}" Width="40" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Font -->
        <GroupBox Header="Font" Padding="8,8">
            <StackPanel Spacing="5">
                <CheckBox dialogs:SettingsSearch.Label="Font Ligature"
                          IsChecked="{Binding EnableLigature, Mode=TwoWay}" Content="Enable Font Ligature" />

                <StackPanel dialogs:SettingsSearch.Label="Font Size"
                            Orientation="Horizontal" Spacing="8">
                    <TextBlock Name="FontSizeLabel" Text="Font Size" VerticalAlignment="Center" />
                    <NumericUpDown Value="{Binding FontSize, Mode=TwoWay}"
                                   Minimum="6" Maximum="72" Increment="0.5"
                                   AutomationProperties.LabeledBy="{Binding #FontSizeLabel}"
                                   FormatString="F1" Width="100" />
                </StackPanel>

                <TextBlock Text="Fonts are searched top to bottom. Drag items to reorder priority."
                           FontSize="11" Foreground="Gray" Margin="0,3,0,3" TextWrapping="Wrap" />

                <Grid dialogs:SettingsSearch.Label="Font Priority">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ListBox Grid.Column="0" ItemsSource="{Binding FontItems}"
                             AutomationProperties.Name="Font priority list"
                             AutomationProperties.HelpText="Drag items to reorder, or use the adjacent buttons."
                             SelectedIndex="{Binding SelectedFontIndex, Mode=TwoWay}"
                             Height="120" Margin="0,0,5,0" />

                    <StackPanel Grid.Column="1" Spacing="3">
                        <Button Content="Add..." Width="76" Click="FontAdd_Click"
                                AutomationProperties.Name="Add font"
                                AutomationProperties.HelpText="Add a font to the priority list." />
                        <Button Content="Remove" Width="76" Click="FontRemove_Click"
                                AutomationProperties.Name="Remove font"
                                IsEnabled="{Binding CanRemoveFont}" />
                        <Button Content="Move Up" Width="76" Click="FontMoveUp_Click"
                                AutomationProperties.Name="Move font up"
                                IsEnabled="{Binding CanMoveUp}" />
                        <Button Content="Move Down" Width="76" Click="FontMoveDown_Click"
                                AutomationProperties.Name="Move font down"
                                IsEnabled="{Binding CanMoveDown}" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </GroupBox>

        <!-- Ligature preview -->
        <GroupBox Header="Ligature preview" Padding="8,8"
                  AutomationProperties.Name="Ligature preview"
                  dialogs:SettingsSearch.Label="Ligature preview">
            <StackPanel Spacing="2">
                <TextBlock dialogs:SettingsSearch.Label="Ligature preview"
                           Text="{Binding LigaturePreviewLine1}"
                           FontFamily="{Binding PreviewFontFamily}"
                           FontSize="{Binding FontSize}"
                           FontFeatures="{Binding PreviewFontFeatures}"
                           TextWrapping="NoWrap" />
                <TextBlock dialogs:SettingsSearch.Label="Ligature preview"
                           Text="{Binding LigaturePreviewLine2}"
                           FontFamily="{Binding PreviewFontFamily}"
                           FontSize="{Binding FontSize}"
                           FontFeatures="{Binding PreviewFontFeatures}"
                           TextWrapping="NoWrap" />
                <TextBlock dialogs:SettingsSearch.Label="Ligature preview"
                           Text="{Binding LigaturePreviewLine3}"
                           FontFamily="{Binding PreviewFontFamily}"
                           FontSize="{Binding FontSize}"
                           FontFeatures="{Binding PreviewFontFeatures}"
                           TextWrapping="NoWrap" />
                <TextBlock Text="Rendered with the current font priority and size."
                           FontSize="11" FontStyle="Italic" Foreground="Gray"
                           Margin="0,4,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </GroupBox>

        <!-- Color Scheme -->
        <GroupBox Header="Color Scheme" Padding="8,8">
            <StackPanel dialogs:SettingsSearch.Label="Color Scheme"
                        Spacing="8">
                <ComboBox ItemsSource="{Binding ColorSchemes}"
                          AutomationProperties.Name="Color scheme"
                          SelectedItem="{Binding SelectedColorScheme, Mode=TwoWay}"
                          Width="250" HorizontalAlignment="Left">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:ColorScheme">
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Preview swatches: first 6 palette colors -->
                <ItemsControl ItemsSource="{Binding PreviewSwatches}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="x:Int32">
                            <Border Width="24" Height="24" CornerRadius="3">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding Converter={x:Static vm:IntColorConverter.Instance}}" />
                                </Border.Background>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </GroupBox>

        <!-- Bell -->
        <GroupBox Header="Bell" Padding="8,8">
            <StackPanel dialogs:SettingsSearch.Label="Bell"
                        Spacing="5">
                <TextBlock Text="Action when the terminal sends BEL (Ctrl+G)"
                           FontSize="11" Foreground="Gray" TextWrapping="Wrap" />
                <ComboBox ItemsSource="{Binding BellActions}"
                          AutomationProperties.Name="Bell action"
                          SelectedItem="{Binding BellAction, Mode=TwoWay}"
                          Width="200" HorizontalAlignment="Left" />
            </StackPanel>
        </GroupBox>

        <!-- Scrollback -->
        <GroupBox Header="Scrollback" Padding="8,8">
            <StackPanel Spacing="5">
                <StackPanel dialogs:SettingsSearch.Label="Scrollback lines"
                            Orientation="Horizontal" Spacing="8">
                    <TextBlock Name="ScrollbackLabel" Text="Scrollback lines" VerticalAlignment="Center" />
                    <NumericUpDown Value="{Binding ScrollbackLines, Mode=TwoWay}"
                                   Minimum="0" Maximum="100000" Increment="100"
                                   AutomationProperties.LabeledBy="{Binding #ScrollbackLabel}"
                                   FormatString="F0" Width="140" />
                </StackPanel>
                <TextBlock Text="Number of lines retained off-screen. Set to 0 to disable scrollback."
                           FontSize="11" Foreground="Gray" TextWrapping="Wrap" />
            </StackPanel>
        </GroupBox>
        <!-- General: settings that don't have a dedicated page yet. -->
        <GroupBox Header="General" Padding="8,8">
            <StackPanel Spacing="5">
                <CheckBox dialogs:SettingsSearch.Label="Confirm on close"
                          IsChecked="{Binding ConfirmOnClose, Mode=TwoWay}"
                          Content="Confirm before closing a window with multiple tabs" />

                <CheckBox dialogs:SettingsSearch.Label="Middle-click paste"
                          IsChecked="{Binding MiddleClickPastes, Mode=TwoWay}"
                          Content="Middle-click pastes (PRIMARY selection on Linux/X11, clipboard elsewhere)" />

                <CheckBox dialogs:SettingsSearch.Label="Quake mode"
                          IsChecked="{Binding QuakeModeEnabled, Mode=TwoWay}"
                          Content="Enable Quake-style dropdown terminal (global hotkey)" />

                <StackPanel dialogs:SettingsSearch.Label="Quake hotkey"
                            Orientation="Horizontal" Spacing="8" Margin="20,0,0,0"
                            IsEnabled="{Binding QuakeModeEnabled}">
                    <TextBlock Text="Quake hotkey" VerticalAlignment="Center" />
                    <TextBox Text="{Binding QuakeHotkey, Mode=TwoWay}" Width="180" />
                    <TextBlock Text="{Binding QuakeHotkeyStatus}" VerticalAlignment="Center"
                               Foreground="{Binding QuakeHotkeyStatusBrush}" FontSize="11" />
                </StackPanel>

                <TextBlock Text="Press the hotkey from any app to toggle a dropdown terminal."
                           FontSize="11" Foreground="Gray" Margin="20,0,0,0" TextWrapping="Wrap" />

                <TextBlock Text="{Binding QuakePlatformWarning}"
                           IsVisible="{Binding HasQuakePlatformWarning}"
                           FontSize="11" Foreground="#CC7700" Margin="20,2,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </GroupBox>
    </StackPanel>
</UserControl>
