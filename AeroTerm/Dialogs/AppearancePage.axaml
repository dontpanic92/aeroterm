<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AeroTerm.ViewModels"
             xmlns:dialogs="using:AeroTerm.Dialogs"
             xmlns:themeControls="using:AeroTerm.Theme.Controls"
             xmlns:strings="using:AeroTerm.Resources"
             x:Class="AeroTerm.Dialogs.AppearancePage"
             x:CompileBindings="True"
             x:DataType="vm:AppearancePageViewModel">
    <StackPanel Spacing="10">
        <GroupBox Header="{x:Static strings:Strings.AppearanceWindowHeader}" Padding="8,8">
            <StackPanel>
                <CheckBox dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.WindowTransparency}"
                          IsChecked="{Binding EnableBlurBehind, Mode=TwoWay}" Content="{x:Static strings:Strings.AppearanceEnableTransparency}" Margin="0,0,0,5" />

                <RadioButton dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.TransparentBlur}"
                             Content="Transparent" GroupName="BlurKind" Margin="20,0,0,3"
                             IsEnabled="{Binding IsTransparentEnabled}"
                             IsChecked="{Binding BlurType, Converter={x:Static vm:BlurTypeConverter.Transparent}, Mode=TwoWay}" />

                <RadioButton dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.GaussianBlur}"
                             Content="Blur (Gaussian)" GroupName="BlurKind" Margin="20,0,0,3"
                             IsEnabled="{Binding IsGaussianEnabled}"
                             IsChecked="{Binding BlurType, Converter={x:Static vm:BlurTypeConverter.Gaussian}, Mode=TwoWay}" />

                <RadioButton dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.AcrylicBlur}"
                             Content="Acrylic Blur" GroupName="BlurKind" Margin="20,0,0,3"
                             IsEnabled="{Binding IsAcrylicEnabled}"
                             IsChecked="{Binding BlurType, Converter={x:Static vm:BlurTypeConverter.Acrylic}, Mode=TwoWay}" />

                <RadioButton dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.Mica}"
                             Content="Mica (Windows only)" GroupName="BlurKind" Margin="20,0,0,5"
                             IsEnabled="{Binding IsMicaEnabled}"
                             IsChecked="{Binding BlurType, Converter={x:Static vm:BlurTypeConverter.Mica}, Mode=TwoWay}" />

                <RadioButton dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.LiquidGlass}"
                             Content="Liquid Glass (macOS 26+)" GroupName="BlurKind" Margin="20,0,0,5"
                             IsEnabled="{Binding IsLiquidGlassEnabled}"
                             IsChecked="{Binding BlurType, Converter={x:Static vm:BlurTypeConverter.LiquidGlass}, Mode=TwoWay}" />

                <StackPanel dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.TintOpacity}"
                            Orientation="Horizontal" Margin="20,0,0,0">
                    <TextBlock Name="TintOpacityLabel" Text="Tint Opacity" VerticalAlignment="Center" Width="110" />
                    <Slider Value="{Binding BackgroundTintOpacity, Mode=TwoWay}" Width="200" Minimum="0" Maximum="1"
                            TickFrequency="0.01" IsSnapToTickEnabled="True" Margin="10,0"
                            AutomationProperties.LabeledBy="{Binding #TintOpacityLabel}"
                            IsEnabled="{Binding IsOpacityEnabled}" />
                    <TextBlock Text="{Binding TintOpacityLabel}" Width="40" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.MaterialOpacity}"
                            Orientation="Horizontal" Margin="20,0,0,0">
                    <TextBlock Name="MaterialOpacityLabel" Text="Material Opacity" VerticalAlignment="Center" Width="110" />
                    <Slider Value="{Binding BackgroundMaterialOpacity, Mode=TwoWay}" Width="200" Minimum="0" Maximum="1"
                            TickFrequency="0.01" IsSnapToTickEnabled="True" Margin="10,0"
                            AutomationProperties.LabeledBy="{Binding #MaterialOpacityLabel}"
                            IsEnabled="{Binding IsOpacityEnabled}" />
                    <TextBlock Text="{Binding MaterialOpacityLabel}" Width="40" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.MaterialTone}"
                            Orientation="Horizontal" Margin="20,5,0,0">
                    <TextBlock Text="Material Tone" VerticalAlignment="Center" Width="110" />
                    <RadioButton Content="Light" GroupName="MaterialToneKind" Margin="0,0,10,0"
                                 IsEnabled="{Binding IsMaterialToneEnabled}"
                                 IsChecked="{Binding MaterialTone, Converter={x:Static vm:MaterialToneConverter.Light}, Mode=TwoWay}" />
                    <RadioButton Content="Dark" GroupName="MaterialToneKind"
                                 IsEnabled="{Binding IsMaterialToneEnabled}"
                                 IsChecked="{Binding MaterialTone, Converter={x:Static vm:MaterialToneConverter.Dark}, Mode=TwoWay}" />
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="{x:Static strings:Strings.AppearanceFontHeader}" Padding="8,8">
            <StackPanel Spacing="5">
                <CheckBox dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.FontLigature}"
                          IsChecked="{Binding EnableLigature, Mode=TwoWay}" Content="{x:Static strings:Strings.AppearanceEnableLigature}" />

                <StackPanel dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.FontSize}"
                            Orientation="Horizontal" Spacing="8">
                    <TextBlock Name="FontSizeLabel" Text="Font Size" VerticalAlignment="Center" />
                    <NumericUpDown Value="{Binding FontSize, Mode=TwoWay}"
                                   Minimum="6" Maximum="72" Increment="0.5"
                                   AutomationProperties.LabeledBy="{Binding #FontSizeLabel}"
                                   FormatString="F1" Width="100" />
                </StackPanel>

                <TextBlock Text="Fonts are searched top to bottom. Drag items to reorder priority."
                           FontSize="11" Foreground="Gray" Margin="0,3,0,3" TextWrapping="Wrap" />

                <Grid dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.FontPriority}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ListBox Grid.Column="0" ItemsSource="{Binding FontItems}"
                             AutomationProperties.Name="Font priority list"
                             AutomationProperties.HelpText="Drag items to reorder, or use the adjacent buttons."
                             SelectedIndex="{Binding SelectedFontIndex, Mode=TwoWay}"
                             Height="120" Margin="0,0,5,0" />

                    <StackPanel Grid.Column="1" Spacing="3">
                        <Button Content="{x:Static strings:Strings.ButtonAdd}" Width="76" Click="FontAdd_Click"
                                AutomationProperties.Name="Add font"
                                AutomationProperties.HelpText="Add a font to the priority list." />
                        <Button Content="{x:Static strings:Strings.ButtonRemove}" Width="76" Click="FontRemove_Click"
                                AutomationProperties.Name="Remove font"
                                IsEnabled="{Binding CanRemoveFont}" />
                        <Button Content="{x:Static strings:Strings.ButtonMoveUp}" Width="76" Click="FontMoveUp_Click"
                                AutomationProperties.Name="Move font up"
                                IsEnabled="{Binding CanMoveUp}" />
                        <Button Content="{x:Static strings:Strings.ButtonMoveDown}" Width="76" Click="FontMoveDown_Click"
                                AutomationProperties.Name="Move font down"
                                IsEnabled="{Binding CanMoveDown}" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="Ligature preview" Padding="8,8"
                  AutomationProperties.Name="Ligature preview"
                  dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.LigaturePreview}">
            <StackPanel Spacing="2">
                <TextBlock dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.LigaturePreview}"
                           Text="{Binding LigaturePreviewLine1}"
                           FontFamily="{Binding PreviewFontFamily}"
                           FontSize="{Binding FontSize}"
                           FontFeatures="{Binding PreviewFontFeatures}"
                           TextWrapping="NoWrap" />
                <TextBlock dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.LigaturePreview}"
                           Text="{Binding LigaturePreviewLine2}"
                           FontFamily="{Binding PreviewFontFamily}"
                           FontSize="{Binding FontSize}"
                           FontFeatures="{Binding PreviewFontFeatures}"
                           TextWrapping="NoWrap" />
                <TextBlock dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.LigaturePreview}"
                           Text="{Binding LigaturePreviewLine3}"
                           FontFamily="{Binding PreviewFontFamily}"
                           FontSize="{Binding FontSize}"
                           FontFeatures="{Binding PreviewFontFeatures}"
                           TextWrapping="NoWrap" />
                <TextBlock Text="Rendered with the current font priority and size."
                           FontSize="11" FontStyle="Italic" Foreground="Gray"
                           Margin="0,4,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </GroupBox>

        <GroupBox Header="{x:Static strings:Strings.AppearanceColorSchemeHeader}" Padding="8,8">
            <StackPanel dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.ColorScheme}"
                        Spacing="8">
                <themeControls:NativeDropdown ItemsSource="{Binding ColorSchemes}"
                                              DisplayMemberPath="Name"
                                              AutomationProperties.Name="Color scheme"
                                              SelectedValue="{Binding SelectedColorScheme, Mode=TwoWay}"
                                              Width="250" HorizontalAlignment="Left" />

                <ItemsControl ItemsSource="{Binding PreviewSwatches}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="x:Int32">
                            <Border Width="24" Height="24" CornerRadius="3">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding Converter={x:Static vm:IntColorConverter.Instance}}" />
                                </Border.Background>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </GroupBox>
    </StackPanel>
</UserControl>
