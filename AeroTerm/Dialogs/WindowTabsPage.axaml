<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AeroTerm.ViewModels"
             xmlns:dialogs="using:AeroTerm.Dialogs"
             xmlns:themeControls="using:AeroTerm.Theme.Controls"
             xmlns:strings="using:AeroTerm.Resources"
             x:Class="AeroTerm.Dialogs.WindowTabsPage"
             x:CompileBindings="True"
             x:DataType="vm:WindowTabsPageViewModel">
    <StackPanel Spacing="10">
        <GroupBox Header="{x:Static strings:Strings.AppearanceTabBarHeader}" Padding="8,8">
            <StackPanel Spacing="5">
                <StackPanel dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.TabBarOrientation}"
                            Orientation="Horizontal" Spacing="8">
                    <TextBlock Name="TabBarOrientationLabel"
                               Text="Tab bar orientation" VerticalAlignment="Center" />
                    <themeControls:NativeDropdown ItemsSource="{Binding TabBarOrientations}"
                                                  AutomationProperties.LabeledBy="{Binding #TabBarOrientationLabel}"
                                                  SelectedValue="{Binding TabBarOrientation, Mode=TwoWay}"
                                                  Width="160" HorizontalAlignment="Left" />
                </StackPanel>
                <TextBlock Text="Horizontal renders tabs as a strip above the terminal. Vertical renders them as a narrow rail on the left side."
                           FontSize="11" Foreground="Gray" TextWrapping="Wrap" />
            </StackPanel>
        </GroupBox>

        <GroupBox Header="Closing" Padding="8,8">
            <StackPanel Spacing="5">
                <CheckBox dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.ConfirmOnClose}"
                          IsChecked="{Binding ConfirmOnClose, Mode=TwoWay}"
                          Content="{x:Static strings:Strings.AppearanceConfirmOnClose}" />
            </StackPanel>
        </GroupBox>

        <GroupBox Header="Quake Mode" Padding="8,8">
            <StackPanel Spacing="5">
                <CheckBox dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.QuakeMode}"
                          IsChecked="{Binding QuakeModeEnabled, Mode=TwoWay}"
                          Content="Enable Quake-style dropdown terminal (global hotkey)" />

                <StackPanel dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.QuakeHotkey}"
                            Orientation="Horizontal" Spacing="8" Margin="20,0,0,0"
                            IsEnabled="{Binding QuakeModeEnabled}">
                    <TextBlock Text="Quake hotkey" VerticalAlignment="Center" />
                    <TextBox Text="{Binding QuakeHotkey, Mode=TwoWay}" Width="180" />
                    <TextBlock Text="{Binding QuakeHotkeyStatus}" VerticalAlignment="Center"
                               Foreground="{Binding QuakeHotkeyStatusBrush}" FontSize="11" />
                </StackPanel>

                <TextBlock Text="Press the hotkey from any app to toggle a dropdown terminal."
                           FontSize="11" Foreground="Gray" Margin="20,0,0,0" TextWrapping="Wrap" />

                <TextBlock Text="{Binding QuakePlatformWarning}"
                           IsVisible="{Binding HasQuakePlatformWarning}"
                           FontSize="11" Foreground="#CC7700" Margin="20,2,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </GroupBox>
    </StackPanel>
</UserControl>
