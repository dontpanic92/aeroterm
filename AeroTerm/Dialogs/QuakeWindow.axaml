<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AeroTerm.Dialogs.QuakeWindow"
        Title="AeroTerm Quake"
        WindowDecorations="None"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
