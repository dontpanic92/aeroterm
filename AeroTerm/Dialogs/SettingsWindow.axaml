<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AeroTerm.ViewModels"
        xmlns:dialogs="using:AeroTerm.Dialogs"
        x:Class="AeroTerm.Dialogs.SettingsWindow"
        x:CompileBindings="True"
        x:DataType="vm:SettingsViewModel"
        Title="Settings" Height="480" Width="680"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Main content area: page list + page content -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Page list -->
            <ListBox Grid.Column="0" Margin="0,0,10,0"
                     ItemsSource="{Binding Pages}"
                     SelectedItem="{Binding SelectedPage, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:SettingsPageViewModel">
                        <TextBlock Text="{Binding DisplayName}" Padding="8,4" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Page content -->
            <ContentControl Grid.Column="1" Content="{Binding SelectedPage}">
                <ContentControl.DataTemplates>
                    <DataTemplate DataType="vm:AppearancePageViewModel">
                        <dialogs:AppearancePage />
                    </DataTemplate>

                    <!-- Fallback for pages without a specific template -->
                    <DataTemplate DataType="vm:SettingsPageViewModel">
                        <TextBlock Text="Page content loading..." />
                    </DataTemplate>
                </ContentControl.DataTemplates>
            </ContentControl>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Spacing="8">
            <Button Content="OK" Width="80" Click="OkButton_Click" />
            <Button Content="Cancel" Width="80" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
