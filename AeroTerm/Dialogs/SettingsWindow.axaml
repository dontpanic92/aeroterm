<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AeroTerm.ViewModels"
        xmlns:dialogs="using:AeroTerm.Dialogs"
        x:Class="AeroTerm.Dialogs.SettingsWindow"
        x:CompileBindings="True"
        x:DataType="vm:SettingsViewModel"
        Title="Settings" Height="480" Width="680"
        MinWidth="560" MinHeight="420"
        CanResize="True"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Main content area: page list + page content -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar: search box + filtered page list -->
            <DockPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBox DockPanel.Dock="Top"
                         Name="SearchBox"
                         TabIndex="0"
                         AutomationProperties.Name="Search settings"
                         AutomationProperties.HelpText="Filter the settings pages and options."
                         PlaceholderText="Search settings…"
                         Text="{Binding SearchQuery, Mode=TwoWay}"
                         Margin="0,0,0,6">
                    <TextBox.InnerRightContent>
                        <Button Content="✕"
                                AutomationProperties.Name="Clear search"
                                Padding="4,0"
                                Margin="2,0"
                                BorderThickness="0"
                                Background="Transparent"
                                IsVisible="{Binding SearchQuery, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Click="ClearSearch_Click"
                                ToolTip.Tip="Clear search" />
                    </TextBox.InnerRightContent>
                </TextBox>

                <ListBox Name="PageList"
                         TabIndex="1"
                         AutomationProperties.Name="Settings pages"
                         AutomationProperties.LiveSetting="Polite"
                         ItemsSource="{Binding FilteredPages}"
                         SelectedItem="{Binding SelectedPage, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:SettingsPageViewModel">
                            <TextBlock Text="{Binding DisplayName}" Padding="8,4" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Page content (scrollable so long pages / small windows work) -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Padding="0,0,4,0"
                          TabIndex="2"
                          AutomationProperties.Name="Settings page content"
                          dialogs:SettingsSearch.Query="{Binding SearchQuery}">
                <ContentControl Content="{Binding SelectedPage}">
                    <ContentControl.DataTemplates>
                        <DataTemplate DataType="vm:AppearancePageViewModel">
                            <dialogs:AppearancePage />
                        </DataTemplate>

                        <DataTemplate DataType="vm:UpdatesPageViewModel">
                            <dialogs:UpdatesPage />
                        </DataTemplate>

                        <DataTemplate DataType="vm:KeybindingsPageViewModel">
                            <dialogs:KeybindingsPage />
                        </DataTemplate>

                        <DataTemplate DataType="vm:ProfilesPageViewModel">
                            <dialogs:ProfilesPage />
                        </DataTemplate>

                        <!-- Fallback for pages without a specific template -->
                        <DataTemplate DataType="vm:SettingsPageViewModel">
                            <TextBlock Text="Page content loading..." />
                        </DataTemplate>
                    </ContentControl.DataTemplates>
                </ContentControl>
            </ScrollViewer>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Spacing="8">
            <Button Content="_OK" Width="80" TabIndex="3" IsDefault="True"
                    AutomationProperties.Name="OK" Click="OkButton_Click" />
            <Button Content="_Cancel" Width="80" TabIndex="4" IsCancel="True"
                    AutomationProperties.Name="Cancel" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
