<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AeroTerm.ViewModels"
             xmlns:themeControls="using:AeroTerm.Theme.Controls"
             xmlns:dialogs="using:AeroTerm.Dialogs"
             x:Class="AeroTerm.Dialogs.UpdatesPage"
             x:CompileBindings="True"
             x:DataType="vm:UpdatesPageViewModel">
    <StackPanel Spacing="12">
        <!-- Current version -->
        <StackPanel dialogs:SettingsSearch.Label="Current version"
                    Orientation="Horizontal" Spacing="6">
            <TextBlock Text="Current version:" FontWeight="SemiBold" VerticalAlignment="Center" />
            <TextBlock Text="{Binding VersionText}" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Notice for builds without auto-update support -->
        <Border IsVisible="{Binding !SupportsAutoUpdate}"
                Background="#FFF3CD" BorderBrush="#FFECB5" BorderThickness="1"
                CornerRadius="4" Padding="10" Margin="0,0,0,4">
            <TextBlock TextWrapping="Wrap"
                       Text="Auto-updates are not available for this build. Install AeroTerm from a stable or CI release package to enable updates." />
        </Border>

        <!-- Channel selector -->
        <StackPanel dialogs:SettingsSearch.Label="Channel Stable CI"
                    Orientation="Horizontal" Spacing="6"
                    IsEnabled="{Binding SupportsAutoUpdate}">
            <TextBlock Text="Channel:" FontWeight="SemiBold" VerticalAlignment="Center" />
            <themeControls:NativeDropdown SelectedIndex="{Binding SelectedChannelIndex}" Width="140"
                                          AutomationProperties.Name="Update channel">
                <themeControls:NativeDropdownItem Content="Stable" />
                <themeControls:NativeDropdownItem Content="CI" IsEnabled="{Binding CanSwitchToCI}" />
            </themeControls:NativeDropdown>
        </StackPanel>

        <!-- Auto-check toggle -->
        <CheckBox dialogs:SettingsSearch.Label="Check for updates automatically"
                  IsChecked="{Binding AutoCheckForUpdates}"
                  Content="Check for updates automatically at startup" />

        <!-- Last checked -->
        <TextBlock dialogs:SettingsSearch.Label="Last checked"
                   Text="{Binding LastCheckedText, StringFormat='Last checked: {0}'}"
                   Foreground="Gray" FontSize="12" />

        <!-- Update status panel -->
        <Border dialogs:SettingsSearch.Label="Update status download restart skip release notes"
                BorderBrush="LightGray" BorderThickness="1" CornerRadius="4"
                Padding="12" Margin="0,4,0,0">
            <StackPanel Spacing="8">
                <!-- Status text -->
                <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold" />

                <!-- Actions when update is available -->
                <StackPanel IsVisible="{Binding IsUpdateAvailable}" Spacing="6">
                    <TextBlock Text="View Release Notes"
                               Foreground="Blue" TextDecorations="Underline"
                               Cursor="Hand"
                               IsVisible="{Binding ReleaseNotesUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               PointerPressed="ReleaseNotesLink_PointerPressed" />

                    <!-- Download progress -->
                    <StackPanel IsVisible="{Binding IsDownloading}" Spacing="4">
                        <ProgressBar Minimum="0" Maximum="100"
                                     Value="{Binding DownloadProgress}"
                                     Height="16" />
                        <TextBlock Text="{Binding DownloadStatusText}"
                                   Foreground="Gray" FontSize="12" />
                    </StackPanel>

                    <!-- Ready to restart message -->
                    <TextBlock IsVisible="{Binding IsReadyToRestart}"
                               Text="{Binding DownloadStatusText}"
                               Foreground="Green" FontWeight="SemiBold" />

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <!-- Download & Install (shown when update found, not yet downloaded) -->
                        <Button Content="Download &amp; Install"
                                AutomationProperties.Name="Download and install update"
                                Click="DownloadAndInstall_Click"
                                IsVisible="{Binding !IsReadyToRestart}"
                                IsEnabled="{Binding !IsDownloading}" />

                        <!-- Restart to Update (shown after download completes) -->
                        <Button Content="Restart to Update"
                                AutomationProperties.Name="Restart to apply update"
                                Click="RestartToUpdate_Click"
                                IsVisible="{Binding IsReadyToRestart}" />

                        <Button Content="Skip This Version"
                                AutomationProperties.Name="Skip this version"
                                Click="SkipThisVersion_Click"
                                IsVisible="{Binding !IsDownloading}" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Check button -->
        <Button dialogs:SettingsSearch.Label="Check for Updates"
                Content="Check for Updates"
                AutomationProperties.Name="Check for updates"
                Click="CheckForUpdates_Click"
                IsEnabled="{Binding SupportsAutoUpdate}"
                HorizontalAlignment="Left" />
    </StackPanel>
</UserControl>
