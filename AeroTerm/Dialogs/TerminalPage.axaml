<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AeroTerm.ViewModels"
             xmlns:dialogs="using:AeroTerm.Dialogs"
             xmlns:themeControls="using:AeroTerm.Theme.Controls"
             xmlns:strings="using:AeroTerm.Resources"
             x:Class="AeroTerm.Dialogs.TerminalPage"
             x:CompileBindings="True"
             x:DataType="vm:TerminalPageViewModel">
    <StackPanel Spacing="10">
        <GroupBox Header="{x:Static strings:Strings.AppearanceBellHeader}" Padding="8,8">
            <StackPanel dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.Bell}"
                        Spacing="5">
                <TextBlock Text="Action when the terminal sends BEL (Ctrl+G)"
                           FontSize="11" Foreground="Gray" TextWrapping="Wrap" />
                <themeControls:NativeDropdown ItemsSource="{Binding BellActions}"
                                              AutomationProperties.Name="Bell action"
                                              SelectedValue="{Binding BellAction, Mode=TwoWay}"
                                              Width="200" HorizontalAlignment="Left" />
            </StackPanel>
        </GroupBox>

        <GroupBox Header="{x:Static strings:Strings.AppearanceScrollbackHeader}" Padding="8,8">
            <StackPanel Spacing="5">
                <StackPanel dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.ScrollbackLines}"
                            Orientation="Horizontal" Spacing="8">
                    <TextBlock Name="ScrollbackLabel" Text="Scrollback lines" VerticalAlignment="Center" />
                    <NumericUpDown Value="{Binding ScrollbackLines, Mode=TwoWay}"
                                   Minimum="0" Maximum="1000000" Increment="1000"
                                   AutomationProperties.LabeledBy="{Binding #ScrollbackLabel}"
                                   FormatString="F0" Width="160" />
                </StackPanel>
                <TextBlock Text="Number of lines retained off-screen (0-1,000,000). Set to 0 to disable scrollback."
                           FontSize="11" Foreground="Gray" TextWrapping="Wrap" />
                <TextBlock Text="Scrollback is disabled. Lines scrolled off the top are discarded immediately."
                           FontSize="11" Foreground="#E0A030" TextWrapping="Wrap"
                           IsVisible="{Binding ScrollbackDisabledWarningVisible}" />
            </StackPanel>
        </GroupBox>

        <GroupBox Header="Mouse" Padding="8,8">
            <StackPanel Spacing="5">
                <CheckBox dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.MiddleClickPaste}"
                          IsChecked="{Binding MiddleClickPastes, Mode=TwoWay}"
                          Content="Middle-click pastes (PRIMARY selection on Linux/X11, clipboard elsewhere)" />
            </StackPanel>
        </GroupBox>
    </StackPanel>
</UserControl>
