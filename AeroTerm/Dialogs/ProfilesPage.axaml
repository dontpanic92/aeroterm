<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AeroTerm.ViewModels"
             xmlns:svc="using:AeroTerm.Services"
             xmlns:dialogs="using:AeroTerm.Dialogs"
             xmlns:themeControls="using:AeroTerm.Theme.Controls"
             x:Class="AeroTerm.Dialogs.ProfilesPage"
             x:CompileBindings="True"
             x:DataType="vm:ProfilesPageViewModel">
  <ScrollViewer Padding="20,16,16,16"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
    <StackPanel Spacing="20">

      <!-- Profile selector row: dropdown + action buttons. -->
      <StackPanel Spacing="6">
        <TextBlock Name="ProfileSelectorLabel"
                   Text="Profile"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   FontSize="12" />
        <Grid ColumnDefinitions="*,Auto,Auto,Auto">
          <themeControls:NativeDropdown Grid.Column="0"
                                        ItemsSource="{Binding Profiles}"
                                        DisplayMemberPath="Name"
                                        SelectedValue="{Binding SelectedProfile, Mode=TwoWay}"
                                        PlaceholderText="No profiles"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        AutomationProperties.LabeledBy="{Binding #ProfileSelectorLabel}" />
          <Button Grid.Column="1"
                  Margin="6,0,0,0"
                  Padding="10,6"
                  Content="+ New"
                  Background="{DynamicResource AccentPrimaryBrush}"
                  Foreground="{DynamicResource TextOnAccentBrush}"
                  Click="AddButton_Click"
                  AutomationProperties.Name="Add profile" />
          <Button Grid.Column="2"
                  Margin="6,0,0,0"
                  Padding="10,6"
                  Content="Copy"
                  ToolTip.Tip="Duplicate profile"
                  IsEnabled="{Binding HasSelection}"
                  Click="DuplicateButton_Click"
                  AutomationProperties.Name="Duplicate profile" />
          <Button Grid.Column="3"
                  Margin="6,0,0,0"
                  Padding="10,6"
                  Content="Delete"
                  ToolTip.Tip="Remove profile"
                  IsEnabled="{Binding HasSelection}"
                  Click="RemoveButton_Click"
                  AutomationProperties.Name="Remove profile" />
        </Grid>
      </StackPanel>

      <!-- Editor pane. -->
      <StackPanel Spacing="20" IsEnabled="{Binding HasSelection}">

        <!-- Header row: large editable name + default badge / button. -->
        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto"
              dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.ProfileName}">
          <TextBlock Grid.Row="0" Grid.Column="0"
                     Name="ProfileNameLabel"
                     Text="Profile name"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     FontSize="11"
                     Margin="0,0,0,4" />
          <TextBox  Grid.Row="1" Grid.Column="0"
                    Text="{Binding SelectedName, Mode=TwoWay}"
                    AutomationProperties.LabeledBy="{Binding #ProfileNameLabel}" />

          <StackPanel Grid.Row="1" Grid.Column="1"
                      Orientation="Horizontal"
                      VerticalAlignment="Center"
                      Margin="12,0,0,0"
                      dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.DefaultProfile}">
            <Border Background="{DynamicResource AccentMutedBrush}"
                    Padding="10,4"
                    CornerRadius="10"
                    IsVisible="{Binding IsSelectedDefault}">
              <TextBlock Text="Default"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextOnAccentBrush}" />
            </Border>
            <Button Content="Set as default"
                    Padding="12,6"
                    IsVisible="{Binding !IsSelectedDefault}"
                    Click="SetDefaultButton_Click"
                    AutomationProperties.Name="Set as default profile" />
          </StackPanel>
        </Grid>

        <!-- "Launch" section. -->
        <StackPanel Spacing="14">
          <TextBlock Text="Launch"
                     FontSize="13"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextSecondaryBrush}" />

          <!-- Executable path with Browse button. -->
          <StackPanel Spacing="4"
                      dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.Command}">
            <TextBlock Name="ProfileCommandLabel"
                       Text="Executable"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="12" />
            <Grid ColumnDefinitions="*,Auto">
              <TextBox Grid.Column="0"
                       Text="{Binding SelectedCommand, Mode=TwoWay}"
                       AutomationProperties.LabeledBy="{Binding #ProfileCommandLabel}"
                       PlaceholderText="e.g. /bin/zsh - leave empty for the platform default shell" />
              <Button Grid.Column="1"
                      Margin="6,0,0,0"
                      Padding="14,6"
                      Content="Browse..."
                      Click="BrowseExecutable_Click"
                      AutomationProperties.Name="Browse for executable" />
            </Grid>
          </StackPanel>

          <!-- Arguments. -->
          <StackPanel Spacing="4"
                      dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.Arguments}">
            <TextBlock Name="ProfileArgsLabel"
                       Text="Arguments"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="12" />
            <TextBox Text="{Binding SelectedArgsText, Mode=TwoWay}"
                     AutomationProperties.LabeledBy="{Binding #ProfileArgsLabel}"
                     PlaceholderText="whitespace-separated; quote arguments containing spaces" />
          </StackPanel>

          <!-- Working directory with Browse button. -->
          <StackPanel Spacing="4"
                      dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.WorkingDirectory}">
            <TextBlock Name="ProfileCwdLabel"
                       Text="Working directory"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="12" />
            <Grid ColumnDefinitions="*,Auto">
              <TextBox Grid.Column="0"
                       Text="{Binding SelectedWorkingDirectory, Mode=TwoWay}"
                       AutomationProperties.LabeledBy="{Binding #ProfileCwdLabel}"
                       PlaceholderText="leave empty to inherit the user home directory" />
              <Button Grid.Column="1"
                      Margin="6,0,0,0"
                      Padding="14,6"
                      Content="Browse..."
                      Click="BrowseWorkingDirectory_Click"
                      AutomationProperties.Name="Browse for working directory" />
            </Grid>
          </StackPanel>
        </StackPanel>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
