<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AeroTerm.ViewModels"
             xmlns:svc="using:AeroTerm.Services"
             xmlns:themeControls="using:AeroTerm.Theme.Controls"
             xmlns:dialogs="using:AeroTerm.Dialogs"
             x:Class="AeroTerm.Dialogs.ProfilesPage"
             x:CompileBindings="True"
             x:DataType="vm:ProfilesPageViewModel">
    <Grid ColumnDefinitions="200,*" RowDefinitions="*">
        <DockPanel Grid.Column="0" Margin="0,0,10,0">
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="4" Margin="0,6,0,0">
                <Button Content="Add" Click="AddButton_Click"
                        AutomationProperties.Name="Add profile" />
                <Button Content="Duplicate" Click="DuplicateButton_Click"
                        AutomationProperties.Name="Duplicate profile" />
                <Button Content="Remove" Click="RemoveButton_Click"
                        AutomationProperties.Name="Remove profile" />
            </StackPanel>
            <ListBox ItemsSource="{Binding Profiles}"
                     AutomationProperties.Name="Profiles"
                     SelectedItem="{Binding SelectedProfile, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="svc:Profile">
                        <TextBlock Text="{Binding Name}" Padding="4" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <ScrollViewer Grid.Column="1" IsEnabled="{Binding HasSelection}">
            <StackPanel Spacing="8">
                <Grid ColumnDefinitions="140,*" dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.ProfileName}">
                    <TextBlock Grid.Column="0" Name="ProfileNameLabel" Text="Name" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1" Text="{Binding SelectedName, Mode=TwoWay}"
                             AutomationProperties.LabeledBy="{Binding #ProfileNameLabel}" />
                </Grid>

                <Grid ColumnDefinitions="140,*" dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.Command}">
                    <TextBlock Grid.Column="0" Name="ProfileCommandLabel" Text="Command" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1" Text="{Binding SelectedCommand, Mode=TwoWay}"
                             AutomationProperties.LabeledBy="{Binding #ProfileCommandLabel}"
                             PlaceholderText="e.g. /bin/zsh (empty = default shell)" />
                </Grid>

                <Grid ColumnDefinitions="140,*" dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.Arguments}">
                    <TextBlock Grid.Column="0" Name="ProfileArgsLabel" Text="Arguments" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1" Text="{Binding SelectedArgsText, Mode=TwoWay}"
                             AutomationProperties.LabeledBy="{Binding #ProfileArgsLabel}"
                             PlaceholderText="whitespace-separated; quote args with spaces" />
                </Grid>

                <Grid ColumnDefinitions="140,*" dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.WorkingDirectory}">
                    <TextBlock Grid.Column="0" Name="ProfileCwdLabel" Text="Working directory" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1" Text="{Binding SelectedWorkingDirectory, Mode=TwoWay}"
                             AutomationProperties.LabeledBy="{Binding #ProfileCwdLabel}"
                             PlaceholderText="empty = user home" />
                </Grid>

                <Grid ColumnDefinitions="140,*" dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.EnvironmentOverrides}">
                    <TextBlock Grid.Column="0" Name="ProfileEnvLabel" Text="Environment" VerticalAlignment="Top" Margin="0,4,0,0" />
                    <TextBox Grid.Column="1" Text="{Binding SelectedEnvironmentText, Mode=TwoWay}"
                             AutomationProperties.LabeledBy="{Binding #ProfileEnvLabel}"
                             AcceptsReturn="True" MinHeight="72"
                             PlaceholderText="KEY=VALUE per line" />
                </Grid>

                <Grid ColumnDefinitions="140,*" dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.ColorScheme}">
                    <TextBlock Grid.Column="0" Name="ProfileSchemeLabel" Text="Color scheme" VerticalAlignment="Center" />
                    <themeControls:NativeDropdown Grid.Column="1"
                                                  ItemsSource="{Binding ColorSchemes}"
                                                  AutomationProperties.LabeledBy="{Binding #ProfileSchemeLabel}"
                                                  SelectedValue="{Binding SelectedColorSchemeName, Mode=TwoWay}"
                                                  HorizontalAlignment="Stretch" />
                </Grid>

                <Grid ColumnDefinitions="140,*" dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.FontFamilies}">
                    <TextBlock Grid.Column="0" Name="ProfileFontFamiliesLabel" Text="Font families" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1" Text="{Binding SelectedFontFamiliesText, Mode=TwoWay}"
                             AutomationProperties.LabeledBy="{Binding #ProfileFontFamiliesLabel}"
                             PlaceholderText="comma-separated (empty = default)" />
                </Grid>

                <Grid ColumnDefinitions="140,*" dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.FontSize}">
                    <TextBlock Grid.Column="0" Name="ProfileFontSizeLabel" Text="Font size" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1" Text="{Binding SelectedFontSizeText, Mode=TwoWay}"
                             AutomationProperties.LabeledBy="{Binding #ProfileFontSizeLabel}"
                             PlaceholderText="points (empty = default)" />
                </Grid>

                <Grid ColumnDefinitions="140,*" dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.WindowEffect}">
                    <TextBlock Grid.Column="0" Name="ProfileWindowEffectLabel" Text="Window effect" VerticalAlignment="Center" />
                    <themeControls:NativeDropdown Grid.Column="1"
                                                  ItemsSource="{Binding WindowEffects}"
                                                  AutomationProperties.LabeledBy="{Binding #ProfileWindowEffectLabel}"
                                                  SelectedValue="{Binding SelectedWindowEffect, Mode=TwoWay}"
                                                  HorizontalAlignment="Stretch" />
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0"
                            dialogs:SettingsSearch.Label="{x:Static dialogs:SettingsSearchLabels.DefaultProfile}">
                    <Button Content="Set as default" Click="SetDefaultButton_Click"
                            AutomationProperties.Name="Set as default profile"
                            IsEnabled="{Binding !IsSelectedDefault}" />
                    <TextBlock Text="(current default)" Foreground="Gray" VerticalAlignment="Center"
                               IsVisible="{Binding IsSelectedDefault}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
