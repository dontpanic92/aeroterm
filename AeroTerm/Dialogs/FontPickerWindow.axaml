<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AeroTerm.ViewModels"
        x:Class="AeroTerm.Dialogs.FontPickerWindow"
        x:CompileBindings="True"
        x:DataType="vm:FontPickerViewModel"
        Title="Add Font" Height="400" Width="400"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBox Grid.Row="0" Text="{Binding FilterText, Mode=TwoWay}"
                 AutomationProperties.Name="Filter fonts"
                 AutomationProperties.HelpText="Type part of a font name to filter the list."
                 PlaceholderText="Type to filter..." Margin="0,0,0,5" />

        <ListBox Grid.Row="1" ItemsSource="{Binding FilteredFonts}"
                 AutomationProperties.Name="Available fonts"
                 SelectedItem="{Binding SelectedFontName, Mode=TwoWay}"
                 Margin="0,0,0,10" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="76" Margin="0,0,5,0" Click="Ok_Click"
                    AutomationProperties.Name="OK" IsDefault="True" />
            <Button Content="Cancel" Width="76" Click="Cancel_Click"
                    AutomationProperties.Name="Cancel" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
