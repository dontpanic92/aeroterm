<?xml version="1.0" encoding="utf-8"?>
<root>
  <!--
    English (invariant) baseline resource file for AeroTerm UI strings.
    Each entry is looked up by key via AeroTerm.Services.LocalizationHost
    or the strongly-typed AeroTerm.Resources.Strings accessor.

    When adding a new string:
      1. Add a <data name="KeyName"> entry here with an <value>.
      2. (Optional) Add a matching entry to Strings.es.resx (or other
         culture-specific file) to provide a translation.
      3. Add a static property to Strings.cs returning the lookup
         (LocalizationHost.GetString("KeyName")).
      4. Reference from AXAML via {x:Static strings:Strings.KeyName}
         or from code via Strings.KeyName.

    See Resources/README.md for the full extraction pattern.
  -->
  <resheader name="resmimetype">
    <value>text/microsoft-resx</value>
  </resheader>
  <resheader name="version">
    <value>2.0</value>
  </resheader>
  <resheader name="reader">
    <value>System.Resources.ResXResourceReader, System.Windows.Forms</value>
  </resheader>
  <resheader name="writer">
    <value>System.Resources.ResXResourceWriter, System.Windows.Forms</value>
  </resheader>

  <!-- Window titles -->
  <data name="AppTitle" xml:space="preserve">
    <value>AeroTerm</value>
  </data>
