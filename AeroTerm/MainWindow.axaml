<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:strings="using:AeroTerm.Resources"
        x:Class="AeroTerm.MainWindow"
        Title="{x:Static strings:Strings.AppTitle}"
        RequestedThemeVariant="Light"
        TransparencyLevelHint="None"
        Background="Transparent"
        TransparencyBackgroundFallback="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="38"
        WindowDecorations="Full">

    <Window.Resources>
        <SolidColorBrush x:Key="TitleBarForegroundBrush" Color="White" />
        <SolidColorBrush x:Key="TitleBarButtonHoverBrush" Color="#20FFFFFF" />
        <SolidColorBrush x:Key="TitleBarButtonPressedBrush" Color="#40FFFFFF" />
        <SolidColorBrush x:Key="TitleBarCloseHoverBrush" Color="#C42B1C" />
        <SolidColorBrush x:Key="TitleBarClosePressedBrush" Color="#B22A1C" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.titlebar-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TitleBarForegroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.titlebar-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource TitleBarButtonHoverBrush}" />
        </Style>
        <Style Selector="Button.titlebar-btn:pressed">
            <Setter Property="Background" Value="{DynamicResource TitleBarButtonPressedBrush}" />
        </Style>
        <Style Selector="Button.titlebar-close:pointerover">
            <Setter Property="Background" Value="{DynamicResource TitleBarCloseHoverBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.titlebar-close:pressed">
            <Setter Property="Background" Value="{DynamicResource TitleBarClosePressedBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Window.Styles>

    <!--
        Custom Window template that replaces the default.
        Sets Antialias on the root Panel directly, giving the titlebar
        grayscale antialiasing. The terminal content is unaffected because
        TerminalControl uses ICustomDrawOperation with its own SkiaSharp paints.
    -->
    <Window.Template>
        <ControlTemplate TargetType="Window">
            <Panel TextOptions.TextRenderingMode="Antialias">
                <Border Name="PART_TransparencyFallback"
                        IsHitTestVisible="False" />
                <Border Background="{TemplateBinding Background}"
                        IsHitTestVisible="False" />
                <Panel Margin="{TemplateBinding WindowDecorationMargin}"
                       Background="Transparent" />
                <VisualLayerManager>
                    <ContentPresenter Name="PART_ContentPresenter"
                                      Margin="{TemplateBinding Padding}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}" />
                </VisualLayerManager>
            </Panel>
        </ControlTemplate>
    </Window.Template>

    <Panel>
        <!--
            Content area is first so it renders below the title bar in the
            Z-order, enabling the acrylic blur on the title bar to "dig"
            through to the terminal background.
        -->
        <DockPanel Name="ContentDock" LastChildFill="True">
            <!-- Side tab host (used when TabBarOrientation == Vertical).
                 Hidden in Horizontal mode; the strip is re-parented into
                 TitleBarTabHost instead. -->
            <Border Name="SideTabHost" DockPanel.Dock="Left"
                    Background="Transparent" IsVisible="False" />
            <Border Name="TerminalBorder" Background="Transparent" />
        </DockPanel>

        <!-- Custom Title Bar — floats on top of the content area. -->
        <Grid Name="TitleBar" VerticalAlignment="Top" IsHitTestVisible="True">
            <Grid.ColumnDefinitions>
                <!-- Reservation for the macOS native traffic-light cluster.
                     Width is set to ~78px in code-behind on macOS so the
                     trailing tab strip / title text never sits under the
                     close / minimize / zoom buttons. Zero-width on every
                     other platform and in macOS fullscreen mode. -->
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- macOS traffic-light reservation (see column comment). -->
            <Border Grid.Column="0" Name="MacChromeReservation"
                    Width="0" Background="Transparent"
                    IsHitTestVisible="False" />

            <!-- Logo -->
            <TextBlock Grid.Column="1" Name="LogoText"
                       Text="AeroTerm" VerticalAlignment="Center"
                       Margin="12,0,8,0"
                       Foreground="{DynamicResource TitleBarForegroundBrush}"
                       FontSize="12" FontWeight="Bold" />

            <!-- Tab strip host (used when TabBarOrientation == Horizontal).
                 Stretches across the titlebar; blank trailing area still
                 bubbles pointer presses up to TitleBar_PointerPressed for
                 window dragging. ClipToBounds keeps any transient overflow
                 (e.g., during a tab insertion measure pass) from painting
                 over the trailing system buttons. -->
            <Border Grid.Column="2" Name="TitleBarTabHost"
                    Background="Transparent"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    ClipToBounds="True" />

            <!-- Title (shown when TabBarOrientation == Vertical; the
                 horizontal tab strip occupies the same visual slot). -->
            <TextBlock Grid.Column="3" Name="TitleText" Text=""
                       VerticalAlignment="Center" HorizontalAlignment="Right"
                       Margin="8,0" TextTrimming="CharacterEllipsis"
                       Foreground="{DynamicResource TitleBarForegroundBrush}"
                       FontSize="12" />

            <!-- Settings Button -->
            <Button Grid.Column="4" Name="SettingsButton" Content="⚙"
                    AutomationProperties.Name="Settings"
                    ToolTip.Tip="Settings"
                    Classes="titlebar-btn"
                    Width="46" VerticalAlignment="Stretch" FontSize="14"
                    CornerRadius="0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Focusable="False"
                    Click="SettingsButton_Click" />

            <!-- Minimize Button -->
            <Button Grid.Column="5" Name="MinimizeButton" Content="&#x1F5D5;"
                    AutomationProperties.Name="Minimize"
                    ToolTip.Tip="Minimize"
                    Classes="titlebar-btn"
                    Width="46" VerticalAlignment="Stretch" FontSize="14"
                    CornerRadius="0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Focusable="False"
                    Click="MinimizeButton_Click" />

            <!-- Maximize Button -->
            <Button Grid.Column="6" Name="MaximizeButton" Content="&#x1F5D6;"
                    AutomationProperties.Name="Maximize"
                    ToolTip.Tip="Maximize"
                    Classes="titlebar-btn"
                    Width="46" VerticalAlignment="Stretch" FontSize="14"
                    CornerRadius="0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Focusable="False"
                    Click="MaximizeButton_Click" />

            <!-- Close Button -->
            <Button Grid.Column="7" Name="CloseButton" Content="&#x2715;"
                    AutomationProperties.Name="Close"
                    ToolTip.Tip="Close"
                    Classes="titlebar-btn titlebar-close"
                    Width="46" VerticalAlignment="Stretch" FontSize="14"
                    CornerRadius="0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Focusable="False"
                    Click="CloseButton_Click" />
        </Grid>
    </Panel>
</Window>
