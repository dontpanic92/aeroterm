<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:chrome="using:Avalonia.Controls.Chrome"
             x:Class="AeroTerm.App"
             Name="AeroTerm"
             RequestedThemeVariant="Default">
    <NativeMenu.Menu>
        <NativeMenu>
            <NativeMenuItem Header="New Window"
                            Gesture="⌘+N"
                            Click="OnNewWindowClicked" />
            <NativeMenuItemSeparator />
            <NativeMenuItem Header="Settings..."
                            Gesture="⌘+OemComma"
                            Click="OnSettingsClicked" />
        </NativeMenu>
    </NativeMenu.Menu>
    <Application.Resources>
        <!-- Suppress default WindowDrawnDecorations overlay -->
        <ControlTheme x:Key="{x:Type chrome:WindowDrawnDecorations}"
                       TargetType="chrome:WindowDrawnDecorations">
            <Setter Property="DefaultTitleBarHeight" Value="0" />
            <Setter Property="DefaultFrameThickness" Value="0" />
            <Setter Property="DefaultShadowThickness" Value="0" />
            <Setter Property="Template">
                <WindowDrawnDecorationsTemplate>
                    <WindowDrawnDecorationsContent />
                </WindowDrawnDecorationsTemplate>
            </Setter>
        </ControlTheme>
    </Application.Resources>
    <Application.Styles>
        <SimpleTheme />
    </Application.Styles>
</Application>
